{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Wails: Dev (launch)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}",
      "buildFlags": "-tags dev",
      "env": {
        "CGO_ENABLED": "1"
      },
      "showLog": true
    },
    {
      "name": "Wails: Debug (attach)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "remotePath": "${workspaceFolder}",
      "port": 2345,
      "host": "127.0.0.1",
      "showLog": true
    }
  ]
}
